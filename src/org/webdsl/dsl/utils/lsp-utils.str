module org/webdsl/dsl/utils/lsp-utils

imports
  libstrategolib

rules

  lsp-extract-syntax-highlighting =
    collect-all(\
      appl(prod(_,lit(l),_),_){loc}
      ->
      (l,loc,<if "if"<+"as"<+"is"<+"or"<+"by"<+"in"<+string-length;<gt> (<id>,2) then !"keyword" else !"operator" end> l)
    \)
